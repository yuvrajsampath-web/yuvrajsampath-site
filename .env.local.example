# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# --- Client SDK config (Project settings → General → Your apps → Web app) ---
# These are public by Firebase's design (security comes from Firestore rules,
# not from hiding these), but they only matter for the hidden portal — the
# public site never loads them (see docs/architecture, "Admin SDK vs Client SDK").
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# The one email allowed into the portal (Firebase Auth → Users → the account
# you create for the author). Leave unset to skip the email check (not recommended
# once the site is live).
NEXT_PUBLIC_AUTHOR_EMAIL=

# --- Admin SDK config (Project settings → Service accounts → Generate new key) ---
# Used server-side only, to read Firestore for public pages. Never expose these
# with a NEXT_PUBLIC_ prefix.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n sequences from the downloaded JSON — the app converts them
# back to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
