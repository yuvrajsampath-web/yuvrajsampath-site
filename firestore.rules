rules_version = '2';

// Public pages never read Firestore directly — they go through the Admin SDK
// on the server (see src/lib/data.ts), which ignores these rules entirely.
// So there is no need to open reads to anonymous visitors here: only the
// authenticated author (portal) may read or write, full stop.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthor() {
      return request.auth != null && request.auth.uid == "IBZR4nMr2ZWaeAaSnvs2cM8206D3";
    }

    match /writings/{docId} {
      allow read, write: if isAuthor();
    }
    match /media/{docId} {
      allow read, write: if isAuthor();
    }
    // Subscriber emails: written only via /api/subscribe (Admin SDK, bypasses
    // these rules) so visitors can never read the list or spoof entries —
    // this rule is a deliberate deny-all, not an oversight.
    match /subscribers/{docId} {
      allow read, write: if false;
    }
    // Notification cursor, read/written only by scripts/notify-subscribers.mjs
    // via the Admin SDK.
    match /meta/{docId} {
      allow read, write: if false;
    }
    // Generated book metadata, written only by scripts/generate-books.mjs
    // and read publicly via the Admin SDK (see src/lib/data.ts getBooks()).
    match /books/{docId} {
      allow read, write: if false;
    }
  }
}
